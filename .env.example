# ──────────────────────────────────────────────
# Security Workflow Assistant — Environment Config
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# Deployment environment: development | staging | production
ENVIRONMENT=development

# OpenAI
# Required in production. Must be a real sk-... key.
OPENAI_API_KEY=mock-key
OPENAI_MODEL=gpt-4o

# Database
# SQLite (default, development only):
DATABASE_URL=sqlite:///./security_assistant.db

# CORS: comma-separated list of allowed frontend origins.
# Example for production: https://app.acme.com,https://admin.acme.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
